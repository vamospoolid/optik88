{
  "name": "optik88-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "push": "node deploy/push-github.js",

    "update":         "node deploy/update.js",
    "update:fe":      "node deploy/update.js --only=frontend",
    "update:be":      "node deploy/update.js --only=backend",
    "update:mob":     "node deploy/update.js --only=mobile",
    "update:fe,be":   "node deploy/update.js --only=frontend,backend",
    "update:be,mob":  "node deploy/update.js --only=backend,mobile",

    "deploy":         "node deploy/deploy.js",
    "deploy:fresh":   "node deploy/deploy.js",
    "deploy:vps":     "node deploy/deploy.js --skip-github"
  }
}
